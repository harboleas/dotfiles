# --- Opciones del modo oscuro (Recolor) ---
set recolor true
set recolor-keep-hue false

# Colores de la página (Fondo oscuro y texto gris claro)
set recolor-lightcolor "#1a1a1a"
set recolor-darkcolor  "#e0e0e0"

# --- Interfaz de Zathura (Estilo Nord/Dark) ---
# Fondo general y texto por defecto
set default-bg "#1a1a1a"
set default-fg "#e0e0e0"

# Barra de estado
set statusbar-bg "#2e3440"
set statusbar-fg "#d8dee9"

# Barra de entrada de comandos y búsquedas
set inputbar-bg "#3b4252"
set inputbar-fg "#e5e9f0"

# Resultados de búsqueda (Resaltado)
set highlight-color     "#b48ead"
set highlight-active-color "#a3be8c"

# Mensajes de notificación y error
set notification-bg     "#bf616a"
set notification-fg     "#eceff4"
set notification-error-bg "#bf616a"
set notification-error-fg "#eceff4"

# --- Opciones extras de usabilidad ---
set sandbox none
set selection-clipboard clipboard

